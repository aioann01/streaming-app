{
  "name": "streaming-app",
  "version": "1.0.0",
  "description": "About",
  "author": "Andreas Ioannou",
  "main": "index.js",
  "scripts": {
    "build": "npx nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npx nest start",
    "start:dev": "npx nest start --watch",
    "start:debug": "npx nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --maxWorkers=25%",
    "test:it:local": "newman run test/integration/StreamingApp_IntegrationTests.postman_collection.json -e test/integration/StreamingApp_Local_postman_environment.json -r cli,htmlextra  --reporter-htmlextra-export reports/report.html",
    "test:it" : "newman run test/integration/StreamingApp_IntegrationTests.postman_collection.json -e $IT_ENV_FILE  -r cli,htmlextra  --reporter-htmlextra-export reports/report.html"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aioann01/streaming-app.git"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^4.0.0",
    "@nestjs/jwt": "^10.0.0",
    "typeorm": "^0.3.20",
    "pg": "^8.11.3",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "bcrypt": "^5.1.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.5.6",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^14.3.2"
  },

  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "jest": "^27.4.7",
    "ts-jest": "^27.1.5", 
    "typescript": "4.9.5",
    "newman": "^6.2.2",
    "newman-reporter-htmlextra": "^1.23.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}